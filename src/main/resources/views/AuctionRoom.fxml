<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css" style="-fx-background-color: #f0f0f0;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AuctionController">
    <children>

        <!-- Header -->
        <Pane layoutX="0" layoutY="0" prefHeight="70" prefWidth="1100"
              style="-fx-background-color: linear-gradient(#b21e15, #8e1911); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);">
            <children>
                <Label layoutX="20" layoutY="15" text="🔨 PHÒNG ĐẤU GIÁ TRỰC TUYẾN" textFill="white">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Label fx:id="statusLabel" layoutX="800" layoutY="25" text="Trạng thái: ..." textFill="white">
                    <font><Font size="14.0" /></font>
                </Label>
            </children>
        </Pane>

        <!-- Main Content -->
        <HBox layoutY="80" prefWidth="1100" prefHeight="670" spacing="15">
            <padding><Insets top="10" right="15" bottom="10" left="15" /></padding>

            <!-- Left Panel: Bidding -->
            <VBox spacing="15" prefWidth="550"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <children>
                    <!-- Product Name -->
                    <Label fx:id="productNameLabel" text="TÊN SẢN PHẨM" wrapText="true"
                           style="-fx-text-fill: #2c3e50;">
                        <font><Font name="System Bold" size="28.0" /></font>
                    </Label>

                    <!-- Current Price Box -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #fafafa; -fx-background-radius: 10; -fx-border-color: #b21e15; -fx-border-width: 2; -fx-border-radius: 8; -fx-padding: 15;">
                        <Label text="Giá cao nhất hiện tại:" style="-fx-text-fill: #7f8c8d;">
                            <font><Font size="16.0" /></font>
                        </Label>
                        <Label fx:id="currentPriceLabel" text="0 VNĐ" style="-fx-text-fill: #b21e15;">
                            <font><Font name="System Bold" size="32.0" /></font>
                        </Label>
                    </VBox>

                    <!-- Timer -->
                    <HBox alignment="CENTER"
                          style="-fx-background-color: #2d3436; -fx-background-radius: 10; -fx-padding: 10;">
                        <Label text="⏱ " style="-fx-text-fill: white;">
                            <font><Font size="24.0" /></font>
                        </Label>
                        <Label fx:id="timerLabel" text="00:00:00" textFill="#27ae60">
                            <font><Font name="System Bold" size="48.0" /></font>
                        </Label>
                    </HBox>

                    <!-- Bid Input -->
                    <Separator />
                    <HBox alignment="CENTER" spacing="10">
                        <TextField fx:id="bidAmountField" prefHeight="45" prefWidth="300"
                                   promptText="Nhập số tiền..."
                                   style="-fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
                            <font><Font size="16.0" /></font>
                        </TextField>
                        <Button fx:id="bidButton" text="💰 Trả giá" onAction="#handlePlaceBid"
                                prefHeight="45" prefWidth="130"
                                style="-fx-background-color: linear-gradient(#b21e15, #d63031); -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>
                    </HBox>

                    <Label fx:id="messageLabel" wrapText="true" maxWidth="500" alignment="CENTER" textAlignment="CENTER" />

                    <!-- Auto-bid Section -->
                    <Separator />
                    <Label text="🤖 Đấu Giá Tự Động" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="3">
                            <Label text="Giá tối đa:" style="-fx-font-size: 12px;" />
                            <TextField fx:id="maxBidField" prefWidth="150" promptText="VNĐ" />
                        </VBox>
                        <VBox spacing="3">
                            <Label text="Bước giá:" style="-fx-font-size: 12px;" />
                            <TextField fx:id="bidIncrementField" prefWidth="150" promptText="VNĐ" />
                        </VBox>
                    </HBox>
                    <HBox spacing="10">
                        <Button fx:id="autoBidButton" text="Bật Auto-bid" onAction="#handleSetAutoBid"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" />
                        <Button fx:id="cancelAutoBidButton" text="Tắt Auto-bid" onAction="#handleCancelAutoBid"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" />
                    </HBox>
                    <Label fx:id="autoBidStatusLabel" text="" style="-fx-font-size: 12px;" />
                </children>
            </VBox>

            <!-- Right Panel: History & Chart -->
            <VBox spacing="10" prefWidth="500" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <children>
                    <Label text="📊 Biểu Đồ Giá Đấu" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

                    <!-- Price Chart -->
                    <LineChart fx:id="priceChart" prefHeight="250" style="-fx-background-color: transparent;">
                        <xAxis><CategoryAxis fx:id="xAxis" label="Thời Gian" animated="false" /></xAxis>
                        <yAxis><NumberAxis fx:id="yAxis" label="Giá" autoRanging="true" /></yAxis>
                    </LineChart>

                    <Separator />
                    <Label text="📜 Lịch Sử Đấu Giá" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

                    <!-- Bid History Table -->
                    <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colBidder" text="Người Đấu" prefWidth="130" />
                            <TableColumn fx:id="colAmount" text="Giá Đấu (VNĐ)" prefWidth="150" />
                            <TableColumn fx:id="colTime" text="Thời Gian" prefWidth="150" />
                        </columns>
                        <placeholder><Label text="Chưa có lượt đấu giá nào" /></placeholder>
                    </TableView>
                </children>
            </VBox>
        </HBox>

    </children>
</AnchorPane>
