<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootStack" prefHeight="780.0" prefWidth="1240.0" stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.client.controller.AuctionController">
    <children>
        <BorderPane styleClass="auction-root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="auction-header">
            <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
            <Button fx:id="backButton" text="←" onAction="#handleBackToDashboard" styleClass="auction-back-button">
                <tooltip><Tooltip text="Quay lại sàn" /></tooltip>
            </Button>
            <VBox spacing="2">
                <Label text="Phòng đấu giá BidShift" styleClass="page-title" />
                <Label text="Vai trò được xác định theo từng phòng đấu giá" styleClass="page-subtitle" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" text="Trạng thái: ..." styleClass="status-pill" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" pannable="true" styleClass="auction-room-scroll" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="14" styleClass="auction-center-shell">
                    <padding><Insets top="18" right="24" bottom="24" left="24" /></padding>

            <HBox spacing="18" styleClass="auction-content" VBox.vgrow="ALWAYS">
            <VBox spacing="14" prefWidth="520" maxWidth="560" styleClass="auction-left-panel">
                <Label fx:id="productNameLabel" text="TÊN SẢN PHẨM" wrapText="true" styleClass="auction-product-name" />
                <Label fx:id="roomRoleLabel" text="" wrapText="true" styleClass="seller-view-badge" managed="false" visible="false" />
                <StackPane prefHeight="224" styleClass="auction-room-media">
                    <ImageView fx:id="productImageView" fitHeight="224" fitWidth="500" preserveRatio="false" />
                </StackPane>
                <Label fx:id="productDetailsLabel" text="Chi tiết" wrapText="true" styleClass="auction-details" />
                <Label fx:id="bidCountLabel" text="0 lượt đấu giá" styleClass="auction-bid-count" />

                <VBox alignment="CENTER" spacing="6" styleClass="auction-price-box">
                    <Label text="Giá cao nhất hiện tại" styleClass="auction-price-label" />
                    <Label fx:id="currentPriceLabel" text="0 VNĐ" styleClass="auction-price-value" />
                </VBox>

                <HBox alignment="CENTER" spacing="10" styleClass="auction-timer-box">
                    <Label text="Còn lại" styleClass="auction-timer-label" />
                    <Label fx:id="timerLabel" text="00:00:00" styleClass="auction-timer-value" />
                </HBox>

                <HBox fx:id="bidPanel" alignment="CENTER" spacing="10" styleClass="bid-entry-panel">
                    <TextField fx:id="bidAmountField" prefHeight="46" promptText="Nhập số tiền..." HBox.hgrow="ALWAYS" />
                    <Button fx:id="bidButton" text="Trả giá" onAction="#handlePlaceBid" prefHeight="46" styleClass="primary-button" />
                </HBox>

                <Label fx:id="messageLabel" wrapText="true" maxWidth="500" alignment="CENTER" textAlignment="CENTER" styleClass="auction-message" />
                <TextFlow fx:id="guestLoginPrompt" managed="false" visible="false" textAlignment="CENTER" maxWidth="500" styleClass="guest-login-prompt">
                    <Text fx:id="guestLoginLink" text="Đăng nhập" onMouseClicked="#handleGuestLogin" styleClass="guest-login-link" />
                    <Text text=" để tham gia đấu giá." styleClass="guest-login-text" />
                </TextFlow>

                <Separator fx:id="bidSeparator" />

                <VBox fx:id="autoBidPanel" spacing="10" styleClass="auto-bid-panel">
                    <Label text="Đấu giá tự động" styleClass="section-title" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Giá tối đa" styleClass="input-label" />
                            <TextField fx:id="maxBidField" promptText="VNĐ" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Bước giá" styleClass="input-label" />
                            <TextField fx:id="bidIncrementField" promptText="VNĐ" />
                        </VBox>
                    </HBox>
                    <HBox spacing="10">
                        <Button fx:id="autoBidButton" text="Bật tự động" onAction="#handleSetAutoBid" styleClass="secondary-button" />
                        <Button fx:id="cancelAutoBidButton" text="Tắt tự động" onAction="#handleCancelAutoBid" styleClass="ghost-button" />
                    </HBox>
                    <Label fx:id="autoBidStatusLabel" text="" styleClass="auction-autobid-status" />
                </VBox>
            </VBox>

            <VBox spacing="14" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="auction-right-panel">
                <Label text="Biểu đồ giá đấu" styleClass="section-title" />
                <LineChart fx:id="priceChart" prefHeight="260" styleClass="auction-chart">
                    <xAxis><CategoryAxis fx:id="xAxis" label="Thời gian" animated="false" /></xAxis>
                    <yAxis><NumberAxis fx:id="yAxis" label="Giá" autoRanging="true" /></yAxis>
                </LineChart>

                <Separator />
                <Label text="Lịch sử đấu giá trực tiếp" styleClass="section-title" />
                <ListView fx:id="bidHistoryFeed" VBox.vgrow="ALWAYS" styleClass="chat-list-view">
                    <placeholder><Label text="Chưa có lượt đấu giá nào" /></placeholder>
                </ListView>
            </VBox>
            </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
        </BorderPane>
    </children>
</StackPane>
