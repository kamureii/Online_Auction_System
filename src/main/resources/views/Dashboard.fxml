<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" alignment="TOP_CENTER" prefHeight="650.0" prefWidth="950.0"
      styleClass="root" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.DashboardController">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30" />
    </padding>

    <children>
        <!-- Header -->
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: linear-gradient(#b21e15, #8e1911); -fx-background-radius: 10; -fx-padding: 15;">
            <Label text="🔨 HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="20.0" /></font>
            </Label>
        </HBox>

        <!-- User Info & Controls -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label fx:id="userInfoLabel" text="👤 Chưa đăng nhập" styleClass="input-label" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🔄 Làm mới" onAction="#handleRefresh" styleClass="secondary-button" />
            <Button fx:id="addItemBtn" text="➕ Đăng bán sản phẩm" onAction="#handleOpenAddForm" styleClass="login-button" />
            <Button fx:id="adminBtn" text="⚙️ Quản trị" onAction="#handleOpenAdmin" styleClass="secondary-button" />
            <Button text="🚪 Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" />
        </HBox>

        <Label text="📋 Danh sách phiên đấu giá (Double-click để vào phòng đấu giá)" styleClass="input-label" />

        <!-- Auction Table -->
        <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="colItemName" text="Sản Phẩm" prefWidth="300.0" />
                <TableColumn fx:id="colCurrentBid" text="Giá Cao Nhất (VNĐ)" prefWidth="200.0" />
                <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="120.0" />
                <TableColumn fx:id="colEndTime" text="Thời Gian Kết Thúc" prefWidth="200.0" />
            </columns>
            <placeholder>
                <Label text="Chưa có phiên đấu giá nào" />
            </placeholder>
        </TableView>
    </children>
</VBox>
