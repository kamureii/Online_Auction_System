<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="760.0" styleClass="auth-root" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.RegisterController">
    <center>
        <HBox alignment="CENTER" styleClass="auth-stage">
            <padding><Insets top="28" right="44" bottom="28" left="44" /></padding>
            <VBox alignment="CENTER_LEFT" spacing="13" styleClass="auth-panel">
                <Button text="← Trang chủ" onAction="#handleBackHome" styleClass="auth-home-button" />

                <VBox spacing="4">
                    <Label text="Tạo tài khoản BidShift" styleClass="auth-brand" />
                    <Label text="Mỗi tài khoản đều có thể đăng bán hoặc tham gia đấu giá tùy từng phòng." styleClass="auth-subtitle" wrapText="true" />
                </VBox>

                <VBox spacing="7">
                    <Label styleClass="input-label" text="Họ và tên" />
                    <TextField fx:id="fullnameField" promptText="Nhập đầy đủ họ tên" />
                </VBox>

                <VBox spacing="7">
                    <Label styleClass="input-label" text="Email" />
                    <TextField fx:id="emailField" promptText="example@gmail.com" />
                </VBox>

                <VBox spacing="7">
                    <Label styleClass="input-label" text="Tên đăng nhập" />
                    <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập mới" />
                </VBox>

                <HBox spacing="12">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="input-label" text="Mật khẩu" />
                        <PasswordField fx:id="passwordField" promptText="Ít nhất 6 ký tự" />
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label styleClass="input-label" text="Xác nhận mật khẩu" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu" />
                    </VBox>
                </HBox>

                <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="login-button" text="Đăng ký" />

                <HBox alignment="CENTER" spacing="6.0">
                    <Label text="Đã có tài khoản?" styleClass="auth-note" />
                    <Label onMouseClicked="#goToLogin" styleClass="link-text" text="Đăng nhập ngay" />
                </HBox>

                <Label fx:id="messageLabel" textAlignment="CENTER" wrapText="true" maxWidth="Infinity" alignment="CENTER" styleClass="form-message" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
