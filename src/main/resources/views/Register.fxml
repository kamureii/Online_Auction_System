<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="500.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.RegisterController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" styleClass="login-container"
              AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="30.0">

            <VBox alignment="CENTER" spacing="8.0">
                <Label styleClass="brand-label" text="ĐĂNG KÝ TÀI KHOẢN" />
                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Đã có tài khoản?" style="-fx-font-size: 13px;"/>
                    <Label onMouseClicked="#goToLogin" styleClass="link-text" text="Đăng Nhập Ngay">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                </HBox>
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label styleClass="input-label" text="Họ và tên" />
                <TextField fx:id="fullnameField" promptText="Nhập đầy đủ họ tên" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label styleClass="input-label" text="Email" />
                <TextField fx:id="emailField" promptText="example@gmail.com" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label styleClass="input-label" text="Tên đăng nhập" />
                <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập mới" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label styleClass="input-label" text="Mật khẩu" />
                <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" />
            </VBox>

            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label styleClass="input-label" text="Xác nhận mật khẩu" />
                <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu" />
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="login-button" text="ĐĂNG KÝ" />

            <Label fx:id="messageLabel" textAlignment="CENTER" wrapText="true" maxWidth="Infinity" alignment="CENTER" />

        </VBox>
    </children>
</AnchorPane>
